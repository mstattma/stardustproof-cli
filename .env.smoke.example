STARDUSTPROOF_TEST_KEYSTORE_URL=http://localhost:2001
STARDUSTPROOF_TEST_BIN_DIR=./bin
STARDUSTPROOF_TEST_ORG_UUID=
STARDUSTPROOF_TEST_SIGNING_ACCESS_TOKEN=
# Optional: override the c2patool binary used for detached-manifest
# verification. If unset, the smoke uses the one bundled with
# stardustproof-c2pa-signer at
# <site-packages>/stardustproof_c2pa_signer/bin/c2patool, falling back to
# c2patool on PATH.
# STARDUSTPROOF_C2PATOOL=/path/to/c2patool
